# ─────────────────────────────────────────────────────────────────────────────
# AI Code Review — Frontend Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
# Leave empty for local development — Vite dev server will proxy to localhost:3001.
# Set to your Render backend URL for production.
VITE_API_URL=
# Production example:
# VITE_API_URL=https://ai-code-review-backend.onrender.com

# ── Firebase Web Config ───────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
